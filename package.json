{
  "name": "electricity-dashboard",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev:backend": "pnpm --filter @app/backend start:dev",
    "dev:frontend": "pnpm --filter @app/frontend start",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier . --write",
    "test": "pnpm -r test",
    "test:e2e:backend": "pnpm --filter @app/backend test:e2e",
    "check": "pnpm lint && pnpm test && pnpm build",
    "e2e": "pnpm --filter @app/e2e test",
    "verify": "pnpm lint && pnpm test && pnpm test:e2e:backend && pnpm e2e"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
